# Copy to .env and adjust. .env is git-ignored.

# ---- LLM provider switch ----
# One of: ollama (default, local) | openai | anthropic
LLM_PROVIDER=ollama

# ---- Ollama (local) ----
# Model tag pulled on the machine running Ollama (e.g. `ollama pull llama3.2:3b`)
OLLAMA_MODEL=llama3.2:3b
# If Ollama runs on the SAME machine as extractor.py: http://localhost:11434
# If extractor runs on your Mac but Ollama is on the Windows laptop, use its LAN IP:
#   OLLAMA_BASE_URL=http://192.168.1.50:11434
OLLAMA_BASE_URL=http://localhost:11434

# ---- Cloud providers (only needed when LLM_PROVIDER is set to them) ----
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ---- Scraper ----
# Optional GitHub token raises API rate limits for README fetching (60 -> 5000/hr)
# GITHUB_TOKEN=ghp_...
# Number of trending repos to process per run
SCRAPE_LIMIT=25
# README characters fed to the LLM
README_SNIPPET_CHARS=800
